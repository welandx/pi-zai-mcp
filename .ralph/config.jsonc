{
  "agent": {
    "ci_gate": {
      "enabled": true,
      "argv": [
        "npm",
        "run",
        "typecheck"
      ]
    },
    "git_publish_mode": "commit_and_push",
    "runner": "pi",
    "model": "openai-codex/gpt-5.5:high",
    "phases": 3,
    "phase_overrides": {
      "phase1": {
        "runner": "pi",
        "model": "openai-codex/gpt-5.5:high"
      },
      "phase2": {
        "runner": "pi",
        "model": "openai-codex/gpt-5.5:high"
      },
      "phase3": {
        "runner": "pi",
        "model": "openai-codex/gpt-5.5:high"
      }
    }
  },
  "version": 2
}